{
  "name": "@context-keeper/mcp-server",
  "version": "0.1.0",
  "description": "MCP server + live dashboard for context-keeper",
  "main": "dist/index.js",
  "bin": {
    "ctx-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --target=node18 --external:better-sqlite3 --outfile=dist/index.js && chmod +x dist/index.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@context-keeper/core": "*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  }
}
