{
  "name": "@context-keeper/vscode",
  "displayName": "Context Keeper",
  "description": "Universal AI memory layer — works with GitHub Copilot, Cursor, Cline, and more",
  "version": "0.1.0",
  "publisher": "context-keeper",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Other"],
  "keywords": ["ai", "memory", "copilot", "context", "mcp", "cursor"],
  "icon": "assets/icon.png",
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "context-keeper.add",
        "title": "Context Keeper: Add Memory"
      },
      {
        "command": "context-keeper.search",
        "title": "Context Keeper: Search Memory"
      },
      {
        "command": "context-keeper.summary",
        "title": "Context Keeper: Show Summary"
      },
      {
        "command": "context-keeper.init",
        "title": "Context Keeper: Initialize in Project"
      }
    ],
    "chatParticipants": [
      {
        "id": "context-keeper.ctx",
        "name": "ctx",
        "description": "Query your project memory",
        "isSticky": false
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "contextKeeperView",
          "name": "Context Keeper",
          "when": "workspaceFolderCount > 0"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc",
    "watch": "tsc --watch",
    "package": "vsce package",
    "build": "tsc"
  },
  "dependencies": {
    "@context-keeper/core": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.24.0"
  }
}
